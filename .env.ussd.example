# USSD + SMS Integration - Environment Variables Template

# ============================================================================
# AFRIKA TALKING CREDENTIALS (USSD + SMS Gateway)
# ============================================================================

# Afrika Talking API Key (get from https://africastalking.com/dashboard)
AFRIKATALK_API_KEY=your_api_key_here

# Afrika Talking Username
AFRIKATALK_USERNAME=your_username_here

# USSD Code (e.g., *500#)
AFRIKATALK_USSD_CODE=*500#

# USSD Shortcode
AFRIKATALK_USSD_SHORTCODE=123456

# Environment: 'sandbox' for testing, 'production' for live
AFRIKATALK_ENVIRONMENT=sandbox

# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================

# Your server's public URL where Afrika Talking will send USSD callbacks
USSD_WEBHOOK_URL=https://your-domain.com/api/v1/ussd/menu

# SMS Webhook URL (if needed)
SMS_WEBHOOK_URL=https://your-domain.com/api/v1/sms/webhook

# ============================================================================
# SUPABASE (Database + Auth)
# ============================================================================

# Supabase Project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase Public Key (anon key)
SUPABASE_KEY=your_supabase_public_key_here

# Supabase Service Key (for admin operations)
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# ============================================================================
# DATABASE
# ============================================================================

# PostgreSQL Connection String
DATABASE_URL=postgresql://user:password@localhost:5432/farmiq

# Database Connection Pool Size
DB_POOL_SIZE=20
DB_POOL_TIMEOUT=30

# ============================================================================
# M-PESA CONFIGURATION (For USSD Token Purchases)
# ============================================================================

# M-Pesa Daraja API Credentials
MPESA_CONSUMER_KEY=your_daraja_consumer_key
MPESA_CONSUMER_SECRET=your_daraja_consumer_secret

# M-Pesa Endpoints
MPESA_API_URL=https://api.sandbox.safaricom.co.ke
MPESA_BUSINESS_SHORTCODE=123456
MPESA_PASSKEY=your_mpesa_livekey

# ============================================================================
# AI SERVICES (FarmGrow, FarmScore, FarmSuite)
# ============================================================================

# FarmGrow Service
FARMGROW_API_URL=http://localhost:8000/api/v1/farmgrow
FARMGROW_API_KEY=your_farmgrow_key

# FarmScore Service
FARMSCORE_API_URL=http://localhost:8000/api/v1/farmscore
FARMSCORE_API_KEY=your_farmscore_key

# FarmSuite Service
FARMSUITE_API_URL=http://localhost:8000/api/v1/farmsuite
FARMSUITE_API_KEY=your_farmsuite_key

# ============================================================================
# HEDERA BLOCKCHAIN (Token Minting)
# ============================================================================

# Hedera Network
HEDERA_NETWORK=testnet  # testnet or mainnet

# Hedera Operator ID
HEDERA_OPERATOR_ID=0.0.xxxx

# Hedera Operator Key
HEDERA_OPERATOR_KEY=302e020100300b...

# Hedera Token ID
HEDERA_TOKEN_ID=0.0.yearn_token_id

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log Level
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL

# Enable structured logging
ENABLE_STRUCTURED_LOGGING=true

# Sentry (Error tracking)
SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret Key (for admin endpoints)
JWT_SECRET_KEY=your_very_secret_key_at_least_32_chars_long

# CORS Origins (for USSD API access)
CORS_ORIGINS=["https://farmiq.app", "https://admin.farmiq.app"]

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable USSD feature
ENABLE_USSD=true

# Enable SMS features
ENABLE_SMS=true

# Enable bulk SMS campaigns
ENABLE_BULK_SMS=true

# Enable AI services via USSD
ENABLE_USSD_AI_SERVICES=true

# ============================================================================
# TIMEOUTS & LIMITS
# ============================================================================

# USSD Session timeout (minutes)
USSD_SESSION_TIMEOUT=10

# USSD Menu response timeout (seconds)
USSD_MENU_TIMEOUT=30

# SMS delivery retry attempts
SMS_RETRY_ATTEMPTS=3

# SMS bulk batch size
SMS_BULK_BATCH_SIZE=100

# ============================================================================
# TESTING
# ============================================================================

# Test phone numbers (for development)
TEST_PHONE_NUMBERS=["254712345678", "254798765432"]

# Test FarmIQ IDs
TEST_FARMIQ_IDS=["FARM001", "FARM002", "FARM003"]

# ============================================================================
# END OF TEMPLATE
# =============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.ussd in your project root
# 2. Fill in all values with your actual credentials
# 3. Never commit .env files to version control
# 4. Use different values for sandbox and production
# 5. For production, change AFRIKATALK_ENVIRONMENT to 'production'
#
# TESTING THE SETUP:
# python -m pytest tests/test_ussd_integration.py -v
#
# =============================================================================
