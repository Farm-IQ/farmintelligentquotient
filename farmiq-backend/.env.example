# =====================================================================
# FARMIQ ENVIRONMENT VARIABLES
# =====================================================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env file to version control
# =====================================================================

# ===================== APPLICATION =====================
APP_NAME=farmiq
APP_VERSION=1.0.0
APP_ENV=development  # development, staging, production
DEBUG=true
LOG_LEVEL=DEBUG

# ===================== SERVER =====================
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4
API_BASE_URL=http://localhost:8000
CORS_ORIGINS=["http://localhost:4200", "http://localhost:3000"]

# ===================== DATABASE - SUPABASE =====================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SECRET_KEY=your-service-key
DATABASE_URL=postgresql://user:password@localhost:5432/farmiq
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ===================== AUTHENTICATION =====================
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ===================== HEDERA NETWORK =====================
# Testnet or Mainnet
HEDERA_NETWORK=testnet  # testnet or mainnet

# Testnet credentials
HEDERA_TESTNET_ACCOUNT_ID=0.0.xxxxx
HEDERA_TESTNET_PRIVATE_KEY=your-testnet-private-key

# Mainnet credentials (use secrets management in production)
HEDERA_MAINNET_ACCOUNT_ID=0.0.xxxxx
HEDERA_MAINNET_PRIVATE_KEY=your-mainnet-private-key

# Hedera Token Service (HTS)
FIQ_TOKEN_ID=0.0.xxxxx  # Hedera Token ID for FIQ
HEDERA_TREASURY_ACCOUNT=0.0.xxxxx  # Treasury wallet

# Hedera Smart Contracts (HSCS)
ESCROW_CONTRACT_ID=0.0.xxxxx  # Deployed EscrowAccount.sol contract
REVERSAL_CONTRACT_ID=0.0.xxxxx  # Deployed TokenReversal.sol contract

# Hedera Consensus Service (HCS)
HCS_TOPIC_ID=0.0.xxxxx  # HCS topic for audit logs
HCS_PRIVATE_KEY=your-hcs-private-key

# ===================== M-PESA / AFRICA'S TALKING =====================
# Daraja (M-Pesa API)
DARAJA_CONSUMER_KEY=your-consumer-key
DARAJA_CONSUMER_SECRET=your-consumer-secret
DARAJA_BUSINESS_SHORTCODE=174379  # Safaricom shortcode
DARAJA_PASSKEY=your-passkey

# Callback URLs (must be HTTPS in production)
CALLBACK_CONFIRMATION_URL=https://farmiq.example.com/api/v1/payments/mpesa/confirmation
CALLBACK_VALIDATION_URL=https://farmiq.example.com/api/v1/payments/mpesa/validation

# M-Pesa payment rules
MIN_PAYMENT_KES=10
MAX_PAYMENT_KES=150000
TOKENS_PER_1000_KES=100

# ===================== CORTEX MONITORING =====================
# Metrics backend (Prometheus-compatible)
CORTEX_ENDPOINT=http://localhost:3030  # Cortex instance
CORTEX_WRITE_URL=http://localhost:3030/api/prom/push
CORTEX_READ_URL=http://localhost:3030/api/prom/api/v1

# Metric collection
CORTEX_COLLECT_METRICS=true
CORTEX_BATCH_SIZE=100
CORTEX_BATCH_INTERVAL_SECONDS=10

# ===================== GRAFANA =====================
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=your-api-key
GRAFANA_DATASOURCE_NAME=Cortex

# ===================== LOGGING =====================
LOG_FORMAT=json  # json or text
LOG_OUTPUT=both  # file, stdout, or both
LOG_FILE_PATH=./logs/farmiq.log
LOG_FILE_MAX_SIZE_MB=100
LOG_FILE_RETENTION_DAYS=30

# Structured logging
STRUCTURED_LOGGING_ENABLED=true
INCLUDE_REQUEST_ID=true
INCLUDE_USER_ID=true

# ===================== CACHE (IN-PROCESS) =====================
# No Redis needed! All caching is done in-process for performance
CACHE_BACKEND=in_memory              # options: in_memory (only option)
CACHE_MAX_SIZE=10000                 # Maximum cache entries before LRU eviction
CACHE_DEFAULT_TTL=300                # Default time-to-live (seconds) for cache entries
CACHE_CLEANUP_INTERVAL=300           # Run cleanup every N seconds
CACHE_TTL_SECONDS=3600
EMBEDDING_CACHE_TTL_HOURS=168  # 7 days

# ===================== EMBEDDINGS & OLLAMA =====================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL_NAMES=mistral:7b-instruct,nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ===================== STORAGE =====================
# S3 compatible (Supabase Storage, AWS S3, or Minio)
STORAGE_TYPE=supabase  # supabase, s3, or local
STORAGE_BUCKET_NAME=farmiq-documents
STORAGE_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Local storage (for development)
LOCAL_STORAGE_PATH=./storage
UPLOAD_MAX_FILE_SIZE_MB=50

# ===================== DOCUMENT PROCESSING =====================
# OCR Service (Google Vision, Azure Computer Vision, or local Tesseract)
OCR_PROVIDER=google  # google, azure, or local
GOOGLE_VISION_API_KEY=
AZURE_COMPUTER_VISION_ENDPOINT=
AZURE_COMPUTER_VISION_KEY=

# ===================== EMAIL / NOTIFICATIONS =====================
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@farmiq.example.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===================== SECURITY =====================
# HTTPS/SSL
HTTPS_ENABLED=false  # true in production
SSL_CERT_PATH=
SSL_KEY_PATH=

# ===================== PHASE 3: AI USAGE TRACKING & QUOTAS =====================
# Token quota configuration for all users

# Daily token budget per user (FIQ tokens)
# Example: 100 = ~100 predictions per day
DEFAULT_DAILY_QUOTA=100.0

# Monthly token budget per user (FIQ tokens)
# Example: 2000 = ~66 predictions per day average
DEFAULT_MONTHLY_QUOTA=2000.0

# Enable quota enforcement
# Set to 'false' to allow unlimited usage (for testing/development only)
ENABLE_QUOTA_ENFORCEMENT=true

# Token cost per service (in FIQ tokens)
FARMGROW_TOKEN_COST=1.0       # Cost per RAG query
FARMSCORE_TOKEN_COST=1.0      # Cost per credit score
FARMSUITE_TOKEN_COST=1.0      # Cost per prediction (yield/price/disease)

# Optional: Premium user quotas (can be overridden per-user in database)
PREMIUM_DAILY_QUOTA=500.0
PREMIUM_MONTHLY_QUOTA=10000.0

# Usage tracking database
# Uses ai_usage_log table for queryable logs
# Uses token_transactions table for Hedera sync

# Audit logging settings
AUDIT_LOG_RETENTION_DAYS=90  # How long to keep audit logs
AUDIT_LOG_BATCH_SIZE=100     # Batch writes to HCS

# ===================== PHASE 3: HEDERA INTEGRATION (EXTENDED) =====================
# Hedera Consensus Service (HCS) - Immutable audit trail
HEDERA_HCS_TOPIC_ID=0.0.xxxxx          # Topic ID for audit logs
HEDERA_HCS_SUBMIT_KEY=your-submit-key  # Key for submitting messages

# Hedera Smart Contracts (HSCS) - Automatic deductions
# Smart contract that automatically deducts tokens from user accounts
HEDERA_HSCS_CONTRACT_ID=0.0.xxxxx      # Deployed FIQ deduction contract
HEDERA_CONTRACT_GAS_LIMIT=100000        # Gas limit per transaction
HEDERA_CONTRACT_FUNCTION_ABI={"name":"deductTokens","inputs":[{"name":"user","type":"address"},{"name":"amount","type":"uint256"}]}

# Hedera Token Service (HTS) - Token transfers
# Configure the FIQ token for payments and rewards
HEDERA_TOKEN_ID=0.0.xxxxx               # FIQ token ID
HEDERA_TOKEN_DECIMALS=2                 # FIQ uses 2 decimal places
HEDERA_TOKEN_SUPPLY=1000000000          # Total FIQ supply (1 billion)

# Wallet auto-provisioning
AUTO_CREATE_WALLETS=true                # Auto-create Hedera wallets for new users
INITIAL_WALLET_BALANCE_FIQ=0.0          # Initial balance for new wallets (in FIQ)

# ===================== PAYMENT & MONETIZATION (PHASE 4+) =====================
# FIQ Token pricing (in KES - Kenyan Shillings)
FIQ_PRICE_KES=1.0  # 1 FIQ = 1 KES

# Token purchase tiers
TOKEN_PACK_SMALL_AMOUNT=100.0           # 100 FIQ (100 KES)
TOKEN_PACK_MEDIUM_AMOUNT=500.0          # 500 FIQ (500 KES)
TOKEN_PACK_LARGE_AMOUNT=2000.0          # 2000 FIQ (2000 KES)
TOKEN_PACK_ENTERPRISE_AMOUNT=10000.0    # 10000 FIQ (10000 KES)

# Bonus rewards (percentage)
PURCHASE_BONUS_PERCENT=10               # 10% bonus on purchases
REFERRAL_BONUS_PERCENT=20               # 20% bonus for referrals
ACTIVITY_REWARD_PERCENT=5               # 5% activity bonus

# ===================== ANALYTICS & REPORTING =====================
# Cross-system analytics
GENERATE_DAILY_REPORTS=true
REPORT_GENERATION_TIME=02:00            # UTC time for daily reports
REPORT_EMAIL_RECIPIENTS=admin@farmiq.example.com

# User activity analytics
TRACK_USER_INTERACTIONS=true
INTERACTION_BATCH_SIZE=1000
INTERACTION_RETENTION_DAYS=30

# ===================== DEPLOYMENT & MONITORING =====================
SENTRY_DSN=                             # Error tracking (optional)
DATADOG_API_KEY=                        # APM monitoring (optional)
NEW_RELIC_LICENSE_KEY=                  # Performance monitoring (optional)

# Health check endpoints
HEALTH_CHECK_INTERVAL_SECONDS=30
HEALTH_CHECK_TIMEOUT_SECONDS=5

# Secrets Management (AWS Secrets Manager, HashiCorp Vault, etc.)
SECRETS_PROVIDER=env  # env, aws, vault, etc
AWS_SECRETS_REGION=us-east-1

# ===================== MONITORING & ALERTING =====================
SENTRY_DSN=
DATADOG_API_KEY=
PROMETHEUS_ENABLED=true

# ===================== FEATURE FLAGS =====================
ENABLE_AI_USAGE_TRACKING=true
ENABLE_ESCROW_SYSTEM=true
ENABLE_REVERSAL_API=true
ENABLE_MPESA_PAYMENTS=true
ENABLE_CORTEX_METRICS=true

# ===================== THIRD-PARTY INTEGRATIONS =====================
# Weather API
WEATHER_API_PROVIDER=openweather  # openweather, weatherapi, etc
WEATHER_API_KEY=

# Market Data API
MARKET_DATA_PROVIDER=tradingconomics  # tradingeconomics, quandl, etc
MARKET_DATA_API_KEY=

# ===================== TESTING =====================
TESTING_MODE=false
TEST_DATABASE_URL=postgresql://user:password@localhost:5432/farmiq_test
MOCKSERVER_URL=http://localhost:9090
