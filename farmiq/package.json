{
  "name": "farmiq",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:farmiq": "node dist/farmiq/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.1.1",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.1",
    "@angular/platform-server": "^21.1.0",
    "@angular/router": "^21.1.1",
    "@angular/service-worker": "^21.1.0",
    "@angular/ssr": "^21.1.2",
    "@hashgraph/sdk": "^2.80.0",
    "@ionic/angular": "^8.7.17",
    "@mapbox/mapbox-gl-draw": "^1.4.0",
    "@supabase/supabase-js": "^2.91.1",
    "@turf/turf": "^6.5.0",
    "africastalking": "^0.7.8",
    "ethers": "^6.16.0",
    "express": "^5.1.0",
    "maplibre-gl": "^4.0.0",
    "ngx-toastr": "^18.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "web3": "^4.8.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.1",
    "@angular/cli": "^21.1.1",
    "@angular/compiler-cli": "^21.1.0",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "dotenv": "^16.6.1",
    "jsdom": "^27.1.0",
    "supabase": "^2.72.8",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
