# FarmIQ Payment System Environment Variables
# Copy this file to .env and update with your actual credentials
# Date: March 18, 2026
# Status: Complete Configuration Template

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
APP_ENV=development                    # development, staging, production
DEBUG=true
LOG_LEVEL=INFO

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/farmiq
REDIS_URL=redis://localhost:6379/0

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ============================================================================
# M-PESA / DARAJA CONFIGURATION
# ============================================================================

# M-Pesa Business Details
DARAJA_BASE_URL=https://sandbox.safaricom.co.ke    # sandbox or production
DARAJA_CONSUMER_KEY=your_consumer_key               # From Daraja dashboard
DARAJA_CONSUMER_SECRET=your_consumer_secret         # From Daraja dashboard
DARAJA_BUSINESS_SHORTCODE=174379                    # Business short code
DARAJA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2c0c58047a86ca1df8b9e3ae89e20847

# M-Pesa Callback URLs (must be public HTTPS)
CALLBACK_CONFIRMATION_URL=https://farmiq.example.com/api/v1/payments/mpesa/confirmation
CALLBACK_VALIDATION_URL=https://farmiq.example.com/api/v1/payments/mpesa/validation

# M-Pesa Configuration
KES_TO_FIQ_RATE=0.1                    # 1 KES = 0.1 FIQ
MINIMUM_PAYMENT_KES=50                 # Minimum payment amount
MAXIMUM_PAYMENT_KES=150000             # Maximum payment amount

# ============================================================================
# AFRIKA TALKING CONFIGURATION
# ============================================================================

# Afrika Talking API Credentials
AFRITALK_API_KEY=your_api_key          # From Afrika Talking dashboard
AFRITALK_USERNAME=sandbox              # sandbox or production username

# Afrika Talking Environment
AFRITALK_BASE_URL=https://api.sandbox.africastalking.com

# USSD Configuration
USSD_SHORT_CODE=*384*46648#            # Your USSD menu code
USSD_SESSION_TIMEOUT_SECONDS=300       # 5 minutes
USSD_CALLBACK_URL=https://farmiq.example.com/api/v1/payments/ussd/callback

# SMS Configuration
SMS_SENDER_ID=FarmIQ                   # Sender ID (max 11 chars)
SMS_BATCH_SIZE=100                     # Batch size for bulk SMS
SMS_DELIVERY_TIMEOUT_SECONDS=600       # 10 minutes
SMS_COST_KES=1                         # Cost per SMS in KES

# ============================================================================
# HEDERA HASHGRAPH CONFIGURATION
# ============================================================================

# Hedera Network
HEDERA_NETWORK=testnet                 # testnet or mainnet
HEDERA_ACCOUNT_ID=0.0.12345            # Your Hedera account ID
HEDERA_PRIVATE_KEY=your_private_key    # Your Hedera private key (keep secret!)

# Hedera Consensus Service (HCS) - Immutable Audit Logging
HEDERA_HCS_TOPIC_ID=0.0.54321          # Will be created automatically if not set
HCS_AUTO_CREATE_TOPIC=true             # Auto-create topic if doesn't exist

# Hedera Token Service (HTS) - FIQ Token Management
HEDERA_TOKEN_ID=0.0.99999              # FIQ Token ID (created in setup)
HEDERA_VAULT_ACCOUNT_ID=0.0.88888      # Vault account holding tokens
HEDERA_TOKEN_DECIMALS=2                # FIQ has 2 decimals
HEDERA_TOKEN_INITIAL_SUPPLY=1000000000 # 1 billion tokens

# Hedera Smart Contracts (optional)
HEDERA_CONTRACT_ID=0.0.77777           # Smart contract ID if used
CONTRACT_GAS_LIMIT=100000
GAS_PRICE_TINYBARS=1

# Hedera Configuration
MAX_TRANSACTION_FEE_HBARS=2             # Maximum transaction fee

# ============================================================================
# PAYMENT GATEWAY CONFIGURATION
# ============================================================================

# Transaction Settings
PAYMENT_CONFIRMATION_TIMEOUT=600       # 10 minutes
TRANSACTION_RETENTION_DAYS=30          # Keep transaction logs for 30 days

# Feature Flags
ENABLE_MOCK_PAYMENTS=false             # For testing (no real charges)
ENABLE_HEDERA_LOGGING=true             # Log all transactions to HCS
ENABLE_SMS_NOTIFICATIONS=true          # Send SMS confirmations
ENABLE_CREDIT_HOLD=true                # Put credit on hold during payment

# ============================================================================
# WEBHOOK & SECURITY
# ============================================================================

# Webhook Security
WEBHOOK_SECRET=your_webhook_secret     # Secret for webhook validation
WEBHOOK_SIGNATURE_ALGORITHM=sha256     # HMAC algorithm

# Rate Limiting
RATE_LIMIT_REQUESTS=100                # Max requests per window
RATE_LIMIT_WINDOW_SECONDS=60           # Time window in seconds

# ============================================================================
# AI USAGE & CREDIT CONFIGURATION
# ============================================================================

# Daily & Monthly Quotas
DAILY_AI_QUOTA=100                     # FIQ tokens per day
MONTHLY_AI_QUOTA=2000                  # FIQ tokens per month

# Service Costs (in FIQ tokens)
FARMGROW_COST=5                        # Cost per FarmGrow query
FARMSCORE_COST=10                      # Cost per credit score check
FARMSUITE_COST=3                       # Cost per analytics report
RAG_CHATBOT_COST=2                     # Cost per RAG query

# ============================================================================
# OPTIONAL: SCALING & PERFORMANCE
# ============================================================================

# Database Connection Pool
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# Cache Configuration
CACHE_TTL_SECONDS=3600                 # 1 hour
CACHE_MAX_SIZE=1000

# ============================================================================
# OPTIONAL: MONITORING & LOGGING
# ============================================================================

# Structured Logging
LOG_FORMAT=json                        # json or text
LOG_FILE=logs/payment.log

# Error Tracking (optional)
# SENTRY_DSN=https://...
# DATADOG_API_KEY=...

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================

# Twilio (for SMS fallback - optional)
# TWILIO_ACCOUNT_SID=...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=...

# Slack Notifications (optional)
# SLACK_WEBHOOK_URL=https://...

# ============================================================================
# NOTES
# ============================================================================
#
# 1. DARAJA_PASSKEY:
#    - Sandbox: bfb279f9aa9bdbcf158e97dd71a467cd2c0c58047a86ca1df8b9e3ae89e20847 (default)
#    - Production: Get from Daraja dashboard
#
# 2. HEDERA_PRIVATE_KEY:
#    - Format: ed25519 hex string
#    - Never commit to version control
#    - Keep in secure vault (e.g., AWS Secrets Manager)
#
# 3. HEDERA_ACCOUNT_ID:
#    - Format: 0.0.XXXXXX
#    - Create account at https://portal.hedera.com
#
# 4. SMS_SENDER_ID:
#    - Sandbox: "FarmIQ" or other test name
#    - Production: Must be registered with Afrika Talking
#
# 5. Callback URLs:
#    - Must be public HTTPS (no localhost)
#    - Must accept POST requests
#    - Must validate signatures
#
# 6. For Production:
#    - Switch HEDERA_NETWORK to mainnet
#    - Update DARAJA_BASE_URL to production
#    - Switch AFRITALK_USERNAME to production
#    - Test thoroughly with small amounts first
#
# ============================================================================

#  GETTING SETUP
# ============================================================================
#
# 1. M-Pesa Setup:
#    a) Go to https://developer.safaricom.co.ke/
#    b) Register for Developer Account
#    c) Create App and get Consumer Key/Secret
#    d) Configure Callback URLs
#    e) Test with Sandbox credentials
#
# 2. Afrika Talking Setup:
#    a) Go to https://africastalking.com
#    b) Sign up for account
#    c) Get API Key
#    d) Configure USSD app (if using)
#    e) Register callback URLs
#
# 3. Hedera Setup:
#    a) Go to https://portal.hedera.com
#    b) Create testnet account
#    c) Get Account ID and Private Key
#    d) Fund account with testnet HBAR
#    e) Create HCS topic and HTS token
#
# ============================================================================
